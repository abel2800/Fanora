{
  "name": "fanora",
  "version": "1.0.0",
  "private": true,
  "description": "Fanora monorepo — Backend API, React web app, and Flutter mobile app",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node scripts/start-all.js",
    "start:all": "node scripts/start-all.js",
    "dev": "node scripts/start-all.js",
    "start:api": "node scripts/run-api.js",
    "start:web": "node scripts/run-web.js",
    "start:mobile": "node scripts/start-mobile.js",
    "dev:web": "npx concurrently -n api,web -c blue,green \"npm run start:api\" \"npm run start:web\"",
    "test:api": "npm test --prefix Backend",
    "build:web": "npm run build --prefix Frontend",
    "analyze:mobile": "cd Mobile && flutter analyze --no-fatal-infos",
    "postinstall": "node scripts/ensure-gitignore.js"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/forms": "^0.5.10",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.7.0",
    "clsx": "^2.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "framer-motion": "^12.23.22",
    "helmet": "^7.1.0",
    "js-cookie": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.63.0",
    "react-hot-toast": "^2.6.0",
    "react-intersection-observer": "^9.16.0",
    "react-player": "^3.3.3",
    "react-query": "^3.39.3",
    "react-router-dom": "^7.9.3",
    "recharts": "^3.2.1",
    "sequelize": "^6.35.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/js-cookie": "^3.0.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "eslint": "^9.36.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "postcss": "^8.5.6",
    "supertest": "^6.3.3",
    "tailwindcss": "^4.1.13",
    "vite": "^7.1.7"
  }
}
