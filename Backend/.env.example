# Server Configuration
PORT=5000
NODE_ENV=development
BACKEND_URL=http://localhost:5000

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fanora
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# JWT Configuration
JWT_SECRET=change_this_to_a_long_random_secret_key
JWT_EXPIRE=30d

# Cloudinary Configuration (Free at cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Configuration (Use Gmail App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# Telebirr API Configuration (Demo values for now)
TELEBIRR_API_URL=https://api.telebirr.com
TELEBIRR_APP_ID=demo_telebirr_app_id
TELEBIRR_APP_KEY=demo_telebirr_app_key
TELEBIRR_PUBLIC_KEY=demo_telebirr_public_key
TELEBIRR_PRIVATE_KEY=demo_telebirr_private_key

# CBE Mobile Banking API Configuration (Demo values for now)
CBE_API_URL=https://api.cbebirr.com
CBE_MERCHANT_ID=demo_cbe_merchant_id
CBE_API_KEY=demo_cbe_api_key
CBE_SECRET_KEY=demo_cbe_secret_key

# Frontend / Mobile deep-link base
FRONTEND_URL=http://localhost:3000
MOBILE_DEEP_LINK_SCHEME=fanora

# File Upload Limits
MAX_FILE_SIZE=50MB
MAX_VIDEO_SIZE=500MB

# Firebase Cloud Messaging (optional push notifications)
FCM_SERVER_KEY=

# SMS OTP provider
# Development: console. Production: afromessage or generic.
SMS_PROVIDER=console
AFRO_MESSAGE_TOKEN=
AFRO_MESSAGE_IDENTIFIER_ID=
AFRO_MESSAGE_SENDER_NAME=Fanora
# Generic provider fallback
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_ID=Fanora

# Live streaming provider
# Supported: mux, cloudflare, external
LIVE_PROVIDER=external
LIVE_RTMP_BASE=rtmp://localhost:1935/live
LIVE_HLS_BASE=http://localhost:8080/hls
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Self-hosted KYC analysis (decision support; manual admin approval is mandatory)
KYC_PROVIDER=manual
KYC_SERVICE_URL=http://127.0.0.1:8001
KYC_SERVICE_TOKEN=
KYC_SERVICE_TIMEOUT_MS=30000
# Base URL the KYC container uses to fetch locally stored /uploads files.
# Docker Desktop example: http://host.docker.internal:5000
KYC_IMAGE_BASE_URL=http://host.docker.internal:5000
# If true, failed/missing automated checks may still be submitted for manual review.
KYC_ALLOW_MANUAL_FALLBACK=false
# Shared by docker-compose.kyc.yml
KYC_MAX_IMAGE_BYTES=8388608
KYC_DOWNLOAD_TIMEOUT_SECONDS=10
KYC_OCR_LANGUAGES=eng+amh
KYC_FACE_MATCH_THRESHOLD=0.68
KYC_FACE_DETECTION_THRESHOLD=0.9
# Paths inside the KYC container; override only when supplying compatible models.
KYC_YUNET_MODEL_PATH=/models/opencv_zoo/face_detection_yunet_2023mar.onnx
KYC_SFACE_MODEL_PATH=/models/opencv_zoo/face_recognition_sface_2021dec.onnx
# Development only: comma-separated hosts allowed to resolve privately (for example host.docker.internal).
KYC_DEV_ALLOWED_HOSTS=
# Optional signed generic provider callback. Positive callbacks never auto-approve.
KYC_WEBHOOK_SECRET=
